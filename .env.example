# Copy to .env (never commit .env)

# Neon PostgreSQL — required. Use the connection string from the Neon dashboard.
# DATABASE_URL=postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require

DATABASE_URL=

# Optional: connection timeout (seconds)
# PGCONNECT_TIMEOUT=15

# CORS — default is only https://phonics-assessment.theateamkidsacademy.in
# For local Next.js, e.g.: CORS_ORIGINS=http://localhost:3000
# CORS_ORIGINS=

OPENAI_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
